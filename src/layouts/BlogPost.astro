---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			imageAlt={heroImageAlt ?? title}
			type="article"
			pubDate={pubDate}
			author="Arun Bhardwaj"
			tags={tags}
		/>
	</head>

	<body>
		<Header />

		<div class="post-layout">
			<article class="post-article">
				<div class="back-link">
					<a href="/blog">← Back to all posts</a>
				</div>

				{tags && tags.length > 0 && (
					<div class="post-tags">
						{tags.map((tag: string) => (
							<span class="tag-pill">{tag}</span>
						))}
					</div>
				)}

				<h1 class="post-title">{title}</h1>
				<p class="post-desc">{description}</p>

				<div class="post-meta">
					<div class="author-info">
						<div class="author-avatar">AB</div>
						<div>
							<div class="author-name">Arun Bhardwaj</div>
							<div class="post-date">
								<FormattedDate date={pubDate} />
								{updatedDate && <span> · Updated <FormattedDate date={updatedDate} /></span>}
							</div>
						</div>
					</div>

					<div class="share-bar">
						<span class="share-label">Share</span>
						<!-- Twitter / X -->
						<a
							class="share-btn share-twitter"
							href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.toString())}`}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Share on X / Twitter"
							title="Share on X"
						>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
							</svg>
						</a>
						<!-- LinkedIn -->
						<a
							class="share-btn share-linkedin"
							href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}`}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Share on LinkedIn"
							title="Share on LinkedIn"
						>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
						</a>
						<!-- WhatsApp -->
						<a
							class="share-btn share-whatsapp"
							href={`https://wa.me/?text=${encodeURIComponent(title + ' ' + Astro.url.toString())}`}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Share on WhatsApp"
							title="Share on WhatsApp"
						>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
							</svg>
						</a>
						<!-- Copy link -->
						<button
							class="share-btn share-copy"
							id="copy-link-btn"
							aria-label="Copy link"
							title="Copy link"
							type="button"
						>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
								<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
							</svg>
						</button>
					</div>
				</div>

				{heroImage && (
					<figure class="hero-image">
						<Image width={1536} height={1024} src={heroImage} alt={heroImageAlt ?? title} />
						{heroImageAlt && <figcaption>{heroImageAlt}</figcaption>}
					</figure>
				)}

				<div class="prose" id="prose-content">
					<slot />
				</div>

				<Comments
					showSupabase={false}
					showGiscus={true}
					postSlug={Astro.url.pathname}
				/>
			</article>

			<aside class="toc-sidebar" id="toc-sidebar">
				<div class="toc-inner">
					<p class="toc-label">ON THIS PAGE</p>
					<nav id="toc-nav" aria-label="Table of contents"></nav>
				</div>
			</aside>
		</div>

		<Footer />
	</body>
</html>

<script>
	// ── Copy link button ──────────────────────────────────────────────────────
	const copyBtn = document.getElementById('copy-link-btn');
	copyBtn?.addEventListener('click', async () => {
		try {
			await navigator.clipboard.writeText(window.location.href);
			copyBtn.classList.add('copied');
			copyBtn.setAttribute('title', 'Copied!');
			setTimeout(() => {
				copyBtn.classList.remove('copied');
				copyBtn.setAttribute('title', 'Copy link');
			}, 2000);
		} catch {
			// Fallback for older browsers
			const ta = document.createElement('textarea');
			ta.value = window.location.href;
			ta.style.position = 'fixed';
			ta.style.opacity = '0';
			document.body.appendChild(ta);
			ta.select();
			document.execCommand('copy');
			document.body.removeChild(ta);
			copyBtn.classList.add('copied');
			setTimeout(() => copyBtn.classList.remove('copied'), 2000);
		}
	});
</script>

<script>
	// ── Table of contents ─────────────────────────────────────────────────────
	const prose = document.getElementById('prose-content');
	const tocNav = document.getElementById('toc-nav');

	if (prose && tocNav) {
		const headings = prose.querySelectorAll('h2, h3');

		if (headings.length > 0) {
			const ul = document.createElement('ul');

			headings.forEach((heading, i) => {
				if (!heading.id) heading.id = `heading-${i}`;
				const li = document.createElement('li');
				li.className = heading.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
				const a = document.createElement('a');
				a.href = `#${heading.id}`;
				a.textContent = heading.textContent ?? '';
				li.appendChild(a);
				ul.appendChild(li);
			});

			tocNav.appendChild(ul);

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const link = tocNav.querySelector(`a[href="#${entry.target.id}"]`);
						if (link && entry.isIntersecting) {
							tocNav.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
							link.classList.add('active');
						}
					});
				},
				{ rootMargin: '-10% 0px -80% 0px' }
			);

			headings.forEach((h) => observer.observe(h));
		} else {
			const sidebar = document.getElementById('toc-sidebar');
			if (sidebar) sidebar.style.display = 'none';
		}
	}
</script>

<style>
	.post-layout {
		display: grid;
		grid-template-columns: 1fr 240px;
		gap: 3rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 2em 5em;
		align-items: start;
	}

	.post-article { min-width: 0; }

	.back-link { margin-bottom: 1.5rem; }

	.back-link a {
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}

	.back-link a:hover { color: var(--accent); }

	.post-tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 1rem;
	}

	.tag-pill {
		font-size: 0.7em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent);
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		padding: 0.2em 0.7em;
		border-radius: 999px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.post-title {
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		line-height: 1.15;
		margin-bottom: 0.75rem;
		color: var(--text);
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		letter-spacing: -0.03em;
	}

	.post-desc {
		font-size: 1.05em;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}

	.post-meta {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.author-info {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.author-avatar {
		width: 38px;
		height: 38px;
		border-radius: 50%;
		background: linear-gradient(135deg, #F97316, #FDBA74);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.75em;
		font-weight: 700;
		color: #fff;
		flex-shrink: 0;
	}

	.author-name {
		font-size: 0.9em;
		font-weight: 600;
		color: var(--text);
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.post-date {
		font-size: 0.8em;
		color: var(--text-dim);
	}

	/* ── Share bar ── */
	.share-bar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.share-label {
		font-size: 0.75em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-dim);
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		margin-right: 0.25rem;
	}

	.share-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: var(--bg-card);
		color: var(--text-muted);
		text-decoration: none;
		cursor: pointer;
		transition: all 0.18s ease;
		padding: 0;
	}

	.share-btn:hover {
		transform: translateY(-2px);
		border-color: var(--accent-border);
	}

	.share-twitter:hover  { color: #000; background: #e7e7e7; }
	.share-linkedin:hover { color: #fff; background: #0a66c2; border-color: #0a66c2; }
	.share-whatsapp:hover { color: #fff; background: #25d366; border-color: #25d366; }
	.share-copy:hover     { color: var(--accent); border-color: var(--accent-border); }
	.share-copy.copied    { color: #16a34a; border-color: #16a34a; background: rgba(22,163,74,0.08); }

	:root[data-theme="dark"] .share-twitter:hover { color: #fff; background: #1a1a1a; }

	.hero-image {
		margin-bottom: 2.5rem;
		border-radius: 12px;
	}

	.hero-image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		display: block;
		object-fit: contain;
	}

	.hero-image figcaption {
		margin-top: 0.6rem;
		text-align: center;
		font-size: 0.8em;
		color: var(--text-dim);
		font-style: italic;
	}

	/* ── Prose ── */
	.prose { color: var(--text-muted); line-height: 1.8; }

	.prose :global(h2) {
		font-size: 1.6em;
		margin: 2em 0 0.75em;
		color: var(--text);
		scroll-margin-top: 80px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		letter-spacing: -0.02em;
	}

	.prose :global(h3) {
		font-size: 1.25em;
		margin: 1.5em 0 0.5em;
		color: var(--text);
		scroll-margin-top: 80px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.prose :global(p) { margin-bottom: 1.5em; color: var(--text-muted); }

	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.prose :global(a:hover) { color: var(--accent-hover); }

	.prose :global(ul), .prose :global(ol) {
		padding-left: 1.5em;
		margin-bottom: 1.5em;
		color: var(--text-muted);
	}

	.prose :global(li) { margin-bottom: 0.4em; }

	.prose :global(img) { border-radius: 10px; margin: 1.5em 0; }

	.prose :global(blockquote) {
		border-left: 3px solid var(--accent);
		padding-left: 1.2em;
		color: var(--text-muted);
		font-style: italic;
		margin: 1.5em 0;
	}

	/* ── TOC Sidebar ── */
	.toc-sidebar {
		position: sticky;
		top: 80px;
	}

	.toc-inner {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1.2rem;
		transition: background 0.3s, border-color 0.3s;
	}

	.toc-label {
		font-size: 0.7em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-dim);
		margin: 0 0 0.75rem;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	#toc-nav :global(ul) {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	#toc-nav :global(li) { margin: 0; }
	#toc-nav :global(.toc-h3) { padding-left: 0.75rem; }

	#toc-nav :global(a) {
		display: block;
		font-size: 0.8em;
		color: var(--text-dim);
		text-decoration: none;
		padding: 0.25em 0.5em;
		border-radius: 4px;
		transition: all 0.15s;
		line-height: 1.4;
	}

	#toc-nav :global(a:hover) {
		color: var(--text);
		background: var(--bg-card-hover);
	}

	#toc-nav :global(a.active) {
		color: var(--accent);
		background: var(--accent-dim);
	}

	@media (max-width: 900px) {
		.post-layout { grid-template-columns: 1fr; padding: 2em 1em 4em; }
		.toc-sidebar { display: none; }
	}

	@media (max-width: 480px) {
		.post-layout { padding: 1.5em 1em 3em; }
		.post-title { font-size: clamp(1.5rem, 6vw, 2rem); }
		.post-desc { font-size: 0.95em; }
		.hero-image { border-radius: 8px; }
		.prose :global(h2) { font-size: 1.35em; }
		.prose :global(h3) { font-size: 1.1em; }
	}
</style>
