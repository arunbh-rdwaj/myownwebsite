---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { projects } from '../../data/projects';

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${project.title} — ${SITE_TITLE}`} description={project.description} />
	</head>
	<body>
		<Header />

		<div class="project-layout">
			<article class="project-article">
				<div class="back-link">
					<a href="/portfolio">← Back to all projects</a>
				</div>

				<div class="project-tags">
					{project.tags.map((tag) => (
						<span class="tag-pill">{tag}</span>
					))}
				</div>

				<h1 class="project-title">{project.title}</h1>
				<p class="project-desc">{project.longDescription}</p>

				<div class="project-actions">
					{project.website && (
						<a href={project.website} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
								<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
							</svg>
							Live Demo
						</a>
					)}
					{project.github && (
						<a href={project.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
							<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
								<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
							</svg>
							View on GitHub
						</a>
					)}
				</div>

				<div class="project-image-placeholder">
					<div class="placeholder-content">
						<div class="placeholder-icon">{project.title.charAt(0)}</div>
						<p>{project.title}</p>
					</div>
				</div>

				<div class="prose-section">
					<h2>About the Project</h2>
					<p>{project.longDescription}</p>
				</div>

				<div class="prose-section">
					<h2>Key Features</h2>
					<ul class="features-list">
						{project.features.map((feature) => (
							<li><span class="feature-dot"></span>{feature}</li>
						))}
					</ul>
				</div>
			</article>

			<aside class="project-sidebar">
				<div class="sidebar-card">
					<h3 class="sidebar-title">Project Info</h3>
					<dl class="info-list">
						<div class="info-row">
							<dt>Status</dt>
							<dd>
								<span class={`status-badge status-${project.status.toLowerCase().replace(' ', '-')}`}>
									{project.status}
								</span>
							</dd>
						</div>
						<div class="info-row"><dt>Date</dt><dd>{project.date}</dd></div>
						<div class="info-row"><dt>Role</dt><dd>{project.role}</dd></div>
						{project.website && (
							<div class="info-row">
								<dt>Website</dt>
								<dd><a href={project.website} target="_blank" rel="noopener noreferrer">{project.website.replace('https://', '')}</a></dd>
							</div>
						)}
						{project.github && (
							<div class="info-row">
								<dt>Repository</dt>
								<dd><a href={project.github} target="_blank" rel="noopener noreferrer">github.com/...</a></dd>
							</div>
						)}
					</dl>
				</div>

				<div class="sidebar-card">
					<h3 class="sidebar-title">Tech Stack</h3>
					<div class="tech-tags">
						{project.tags.map((tag) => (
							<span class="tag-pill">{tag}</span>
						))}
					</div>
				</div>
			</aside>
		</div>

		<Footer />
	</body>
</html>

<style>
	.project-layout {
		display: grid;
		grid-template-columns: 1fr 260px;
		gap: 3rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 2em 5em;
		align-items: start;
	}

	.project-article { min-width: 0; }

	.back-link { margin-bottom: 1.5rem; }

	.back-link a {
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}

	.back-link a:hover { color: var(--accent); }

	.project-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }

	.tag-pill {
		font-size: 0.7em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--accent);
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		padding: 0.2em 0.7em;
		border-radius: 999px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.project-title {
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		line-height: 1.15;
		margin-bottom: 0.75rem;
		color: var(--text);
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		letter-spacing: -0.03em;
	}

	.project-desc {
		font-size: 1em;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
		line-height: 1.7;
	}

	.project-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; }

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.6em 1.3em;
		border-radius: 8px;
		font-size: 0.88em;
		font-weight: 600;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		cursor: pointer;
		transition: all 0.2s ease;
		text-decoration: none;
		border: none;
	}

	.btn-primary { background: var(--accent); color: #fff; }
	.btn-primary:hover { background: var(--accent-hover); color: #fff; transform: translateY(-1px); }

	.btn-outline {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border);
	}

	.btn-outline:hover {
		background: var(--bg-card);
		border-color: var(--accent);
		color: var(--accent);
	}

	.project-image-placeholder {
		width: 100%;
		height: 280px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 2.5rem;
	}

	.placeholder-content { text-align: center; color: var(--text-dim); }

	.placeholder-icon {
		width: 64px;
		height: 64px;
		border-radius: 16px;
		background: var(--accent);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.8em;
		font-weight: 700;
		color: #fff;
		margin: 0 auto 0.75rem;
	}

	.prose-section { margin-bottom: 2.5rem; }

	.prose-section h2 {
		font-size: 1.3em;
		color: var(--text);
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.prose-section p { color: var(--text-muted); line-height: 1.8; }

	.features-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.features-list li {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.95em;
		color: var(--text-muted);
	}

	.feature-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		flex-shrink: 0;
	}

	/* Sidebar */
	.project-sidebar {
		position: sticky;
		top: 80px;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.sidebar-card {
		padding: 1.2rem;
		border-radius: 10px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		transition: background 0.3s, border-color 0.3s;
	}

	.sidebar-title {
		font-size: 0.78em;
		font-weight: 700;
		color: var(--text-dim);
		margin: 0 0 1rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.info-list { display: flex; flex-direction: column; gap: 0.75rem; margin: 0; }

	.info-row { display: flex; flex-direction: column; gap: 0.2rem; }

	.info-row dt {
		font-size: 0.72em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-dim);
	}

	.info-row dd { font-size: 0.85em; color: var(--text-muted); margin: 0; }

	.info-row dd a { color: var(--accent); text-decoration: none; }
	.info-row dd a:hover { color: var(--accent-hover); }

	.status-badge {
		font-size: 0.75em;
		font-weight: 600;
		padding: 0.2em 0.7em;
		border-radius: 999px;
		display: inline-block;
	}

	.status-completed {
		background: rgba(16, 185, 129, 0.15);
		color: #059669;
		border: 1px solid rgba(16, 185, 129, 0.3);
	}

	.status-in-progress {
		background: rgba(245, 158, 11, 0.15);
		color: #d97706;
		border: 1px solid rgba(245, 158, 11, 0.3);
	}

	.tech-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

	@media (max-width: 900px) {
		.project-layout { grid-template-columns: 1fr; padding: 2em 1em 4em; }
		.project-sidebar { position: static; }
	}

	@media (max-width: 480px) {
		.project-title { font-size: clamp(1.6rem, 6vw, 2.2rem); }
		.project-actions { flex-direction: column; gap: 0.75rem; }
		.project-actions .btn { width: 100%; justify-content: center; }
		.project-image-placeholder { height: 180px; }
	}
</style>
