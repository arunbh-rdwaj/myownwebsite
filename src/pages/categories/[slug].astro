---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');

	// Collect all unique tags across all posts
	const tagSet = new Set<string>();
	for (const post of allPosts) {
		for (const tag of post.data.tags ?? []) {
			tagSet.add(tag);
		}
	}

	return [...tagSet].map((tag) => ({
		params: {
			slug: tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
		},
		props: { tag },
	}));
}

interface Props { tag: string; }
const { tag } = Astro.props;

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((p) => (p.data.tags ?? []).includes(tag))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${tag} — ${SITE_TITLE}`}
			description={`All posts tagged with ${tag}.`}
		/>
	</head>
	<body>
		<Header />

		<main>
			<div class="page-header">
				<a href="/categories" class="back-link">← All Categories</a>
				<div class="tag-badge">{tag}</div>
				<h1>{posts.length} post{posts.length !== 1 ? 's' : ''}</h1>
			</div>

			<div class="posts-list">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-row">
						{post.data.heroImage && (
							<div class="post-row-image">
								<Image src={post.data.heroImage} alt={post.data.title} width={160} height={100} />
							</div>
						)}
						<div class="post-row-body">
							<div class="post-row-meta">
								{(post.data.tags ?? []).map((t: string) => (
									<span class={`tag-pill${t === tag ? ' tag-pill--active' : ''}`}>{t}</span>
								))}
							</div>
							<h2 class="post-row-title">{post.data.title}</h2>
							<p class="post-row-desc">{post.data.description}</p>
							<div class="post-row-footer">
								<span class="post-row-date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.readingTime && (
									<span class="post-row-read">{post.data.readingTime} min read</span>
								)}
							</div>
						</div>
						<div class="post-row-arrow">→</div>
					</a>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 3em 1.5em 5em;
	}

	.page-header { margin-bottom: 2.5rem; }

	.back-link {
		display: inline-block;
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 1rem;
		transition: color 0.15s;
	}

	.back-link:hover { color: var(--accent); }

	.tag-badge {
		display: inline-block;
		font-size: 0.75em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #fff;
		background: var(--accent);
		padding: 0.25em 0.8em;
		border-radius: 999px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		margin-bottom: 0.75rem;
	}

	.page-header h1 {
		font-size: 2em;
		margin: 0;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.posts-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-row {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		padding: 1.2rem;
		text-decoration: none;
		color: inherit;
		border-radius: 12px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.post-row:hover {
		border-color: var(--accent-border);
		transform: translateY(-1px);
		box-shadow: var(--shadow-sm);
	}

	.post-row-image {
		flex-shrink: 0;
		width: 140px;
		height: 90px;
		border-radius: 8px;
		overflow: hidden;
	}

	.post-row-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.post-row-body { flex: 1; min-width: 0; }

	.post-row-meta {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 0.4rem;
	}

	.tag-pill {
		font-size: 0.7em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent);
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		padding: 0.15em 0.6em;
		border-radius: 999px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.tag-pill--active {
		color: #fff;
		background: var(--accent);
	}

	.post-row-title {
		font-size: 1.05em;
		color: var(--text);
		margin: 0 0 0.3em;
		line-height: 1.3;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.post-row-desc {
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0 0 0.5em;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-row-footer { display: flex; gap: 1rem; align-items: center; }

	.post-row-date, .post-row-read {
		font-size: 0.78em;
		color: var(--text-dim);
	}

	.post-row-arrow {
		color: var(--text-dim);
		font-size: 1.1em;
		flex-shrink: 0;
		transition: transform 0.2s, color 0.2s;
	}

	.post-row:hover .post-row-arrow {
		transform: translateX(4px);
		color: var(--accent);
	}

	@media (max-width: 600px) {
		.post-row-image { display: none; }
		.post-row-arrow { display: none; }
	}
</style>
