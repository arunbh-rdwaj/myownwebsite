---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

// Build tag map: tag -> post count
const tagMap = new Map<string, number>();
for (const post of allPosts) {
	for (const tag of post.data.tags ?? []) {
		tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
	}
}

const tags = [...tagMap.entries()]
	.sort((a, b) => b[1] - a[1])
	.map(([name, count]) => ({
		name,
		count,
		slug: name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
	}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Categories — ${SITE_TITLE}`} description="Browse blog posts by topic." />
	</head>
	<body>
		<Header />

		<main>
			<div class="page-header">
				<h1>Categories</h1>
				<p class="subtitle">Browse posts by topic.</p>
			</div>

			{tags.length === 0 && <p class="empty">No tags yet.</p>}

			<div class="tags-grid">
				{tags.map((tag) => (
					<a href={`/categories/${tag.slug}/`} class="tag-card">
						<span class="tag-name">{tag.name}</span>
						<span class="tag-count">{tag.count} post{tag.count !== 1 ? 's' : ''}</span>
					</a>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 3em 1.5em 5em;
	}

	.page-header { margin-bottom: 2.5rem; }

	.page-header h1 {
		font-size: 2.8em;
		margin-bottom: 0.3em;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.subtitle {
		color: var(--text-muted);
		font-size: 1em;
		margin: 0;
	}

	.empty { color: var(--text-muted); font-size: 0.95em; }

	.tags-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 1rem;
	}

	.tag-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.4rem 1.2rem;
		border-radius: 12px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.tag-card:hover {
		border-color: var(--accent-border);
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.tag-name {
		font-size: 1em;
		font-weight: 600;
		color: var(--text);
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.tag-count {
		font-size: 0.8em;
		color: var(--accent);
		font-weight: 500;
	}
</style>
