---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import heroAbout from '../assets/edit.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About — ${SITE_TITLE}`}
			description="Software Engineer, builder, AI enthusiast, and home cook sharing tech, ideas, and recipes."
		/>
	</head>
	<body>
		<Header />

		<main>
			<div class="about-layout">
				<div class="about-text">
					<span class="section-label">About Me</span>
					<h1>Hey, I'm <span class="gradient-text">Arun Bhardwaj</span> 👋</h1>

					<p>
						I'm a Software Engineer currently working at the London Stock Exchange Group (LSEG),
						where I work on automation engineering and cloud-based financial systems operating at
						large scale.
					</p>
					<p>
						My background includes full-stack development, cloud infrastructure, AI & machine
						learning, system design, and modern web technologies.
					</p>
					<p>
						Beyond my day job, I enjoy building things on the internet — from AI-powered tools and
						developer projects to content-driven websites and experiments with emerging technologies.
					</p>

					<div class="about-actions">
						<a href="/portfolio" class="btn btn-primary">View Portfolio</a>
						<a href="/resume" class="btn btn-outline">View Resume</a>
					</div>
				</div>

				<div class="about-image-wrap">
					<Image src={heroAbout} alt="Arun Bhardwaj" width={420} height={520} class="about-img" />
				</div>
			</div>

			<section class="topics-section">
				<h2 class="section-title">What I Write About</h2>
				<div class="topics-grid">
					<div class="topic-card">
						<span class="topic-icon">🤖</span>
						<h3>Tech & AI</h3>
						<p>Insights on artificial intelligence, LLMs, and the future of software development.</p>
					</div>
					<div class="topic-card">
						<span class="topic-icon">🛠️</span>
						<h3>Engineering</h3>
						<p>Software engineering tutorials, system design, and development best practices.</p>
					</div>
					<div class="topic-card">
						<span class="topic-icon">🔐</span>
						<h3>Cloud & Security</h3>
						<p>Cloud infrastructure, DevOps, and security-related topics from real-world experience.</p>
					</div>
					<div class="topic-card">
						<span class="topic-icon">🎬</span>
						<h3>AI Video</h3>
						<p>AI video workflows, tools, and experiments for content creators.</p>
					</div>
					<div class="topic-card">
						<span class="topic-icon">🚀</span>
						<h3>Projects</h3>
						<p>Personal projects, side hustles, and ideas I'm exploring and building.</p>
					</div>
					<div class="topic-card">
						<span class="topic-icon">🍳</span>
						<h3>Cooking</h3>
						<p>Recipes and food content over at <a href="https://cookwitharun.com" target="_blank" rel="noopener noreferrer">CookWithArun.com</a>.</p>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 2em 5em;
	}

	.about-layout {
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 4rem;
		align-items: center;
		margin-bottom: 5rem;
	}

	.section-label {
		display: inline-block;
		font-size: 0.72em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		padding: 0.3em 0.9em;
		border-radius: 999px;
		margin-bottom: 1rem;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.about-text h1 {
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.15;
		margin-bottom: 1.5rem;
		color: var(--text);
	}

	.gradient-text {
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.about-text p {
		color: var(--text-muted);
		font-size: 0.95em;
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	.about-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
	}

	/* Buttons */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.65em 1.4em;
		border-radius: 8px;
		font-size: 0.9em;
		font-weight: 600;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		cursor: pointer;
		transition: all 0.2s ease;
		text-decoration: none;
		border: none;
	}

	.btn-primary {
		background: var(--accent);
		color: #fff;
	}

	.btn-primary:hover {
		background: var(--accent-hover);
		color: #fff;
		transform: translateY(-1px);
		box-shadow: var(--shadow-accent);
	}

	.btn-outline {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border);
	}

	.btn-outline:hover {
		background: var(--bg-card);
		border-color: var(--accent);
		color: var(--accent);
	}

	/* Image */
	.about-image-wrap { position: relative; }

	.about-img {
		width: 100%;
		height: auto;
		border-radius: 16px;
		display: block;
		object-fit: cover;
		box-shadow: var(--shadow-md);
	}

	/* Topics */
	.topics-section {
		border-top: 1px solid var(--border);
		padding-top: 3rem;
	}

	.section-title {
		font-size: 1.5em;
		color: var(--text);
		margin-bottom: 1.5rem;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.topics-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.topic-card {
		padding: 1.5rem;
		border-radius: 12px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		transition: border-color 0.2s, transform 0.2s;
	}

	.topic-card:hover {
		border-color: var(--accent-border);
		transform: translateY(-2px);
	}

	.topic-icon {
		font-size: 1.8em;
		display: block;
		margin-bottom: 0.75rem;
	}

	.topic-card h3 {
		font-size: 1em;
		color: var(--text);
		margin-bottom: 0.4rem;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.topic-card p {
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
	}

	.topic-card a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	@media (max-width: 900px) {
		.about-layout { grid-template-columns: 1fr; gap: 2rem; }
		.about-image-wrap { max-width: 320px; }
		.topics-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 600px) {
		main { padding: 2em 1em 4em; }
		.topics-grid { grid-template-columns: 1fr; }
	}
</style>
