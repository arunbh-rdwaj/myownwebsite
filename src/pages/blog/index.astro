---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allCategories = ['All', ...new Set(allPosts.flatMap((p) => p.data.tags ?? []))];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Thoughts on Technology, AI, development, and building in public." />
	</head>
	<body>
		<Header />

		<main>
			<div class="blog-header">
				<h1>Blog</h1>
				<p class="subtitle">Thoughts on Technology, AI, development, and building in public.</p>
			</div>

			<div class="blog-controls">
				<div class="filter-tabs" id="filter-tabs">
					{allCategories.map((cat) => (
						<button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-category={cat}>
							{cat}
						</button>
					))}
				</div>
			</div>

			<p class="results-count" id="results-count"></p>

			<div class="posts-list" id="posts-list">
				{allPosts.map((post) => (
					<a
						href={`/blog/${post.id}/`}
						class="post-row"
						data-tags={(post.data.tags ?? []).join('|||')}
					>
						{post.data.heroImage && (
							<div class="post-row-image">
								<Image src={post.data.heroImage} alt={post.data.title} width={160} height={100} />
							</div>
						)}
						<div class="post-row-body">
							<div class="post-row-meta">
								{(post.data.tags ?? []).map((tag: string) => (
									<span class="tag-pill">{tag}</span>
								))}
							</div>
							<h2 class="post-row-title">{post.data.title}</h2>
							<p class="post-row-desc">{post.data.description}</p>
							<div class="post-row-footer">
								<span class="post-row-date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.readingTime && (
									<span class="post-row-read">{post.data.readingTime} min read</span>
								)}
							</div>
						</div>
						<div class="post-row-arrow">→</div>
					</a>
				))}
			</div>

			<p class="no-results" id="no-results" style="display:none">No posts found.</p>
		</main>

		<Footer />
	</body>
</html>

<script>
	const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const postRows = document.querySelectorAll<HTMLElement>('.post-row');
	const noResults = document.getElementById('no-results') as HTMLElement;
	const resultsCount = document.getElementById('results-count') as HTMLElement;

	let activeTag = 'All';

	function applyFilters() {
		let visible = 0;
		postRows.forEach((row) => {
			const tags = (row.dataset.tags ?? '').split('|||').filter(Boolean);
			const show = activeTag === 'All' || tags.includes(activeTag);
			row.style.display = show ? '' : 'none';
			if (show) visible++;
		});
		noResults.style.display = visible === 0 ? '' : 'none';
		resultsCount.textContent = activeTag !== 'All'
			? `${visible} post${visible !== 1 ? 's' : ''} found`
			: '';
	}

	filterBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			filterBtns.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');
			activeTag = btn.dataset.category ?? 'All';
			applyFilters();
		});
	});
</script>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 3em 1.5em 5em;
	}

	.blog-header { margin-bottom: 2rem; }

	.blog-header h1 {
		font-size: 2.8em;
		margin-bottom: 0.3em;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.subtitle {
		color: var(--text-muted);
		font-size: 1em;
		margin: 0;
	}

	/* Controls */
	.blog-controls {
		margin-bottom: 1.5rem;
	}

	/* Filter tabs */
	.filter-tabs {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.filter-btn {
		padding: 0.35em 1em;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text-muted);
		font-size: 0.85em;
		cursor: pointer;
		transition: all 0.2s ease;
		font-family: var(--font-body, 'Inter', system-ui, sans-serif);
	}

	.filter-btn:hover {
		border-color: var(--accent-border);
		color: var(--text);
		background: var(--accent-dim);
	}

	.filter-btn.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	.results-count {
		font-size: 0.82em;
		color: var(--text-dim);
		margin: 0 0 1rem;
		min-height: 1.2em;
	}

	/* Posts list */
	.posts-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.no-results {
		text-align: center;
		color: var(--text-muted);
		padding: 3em 0;
		font-size: 0.95em;
	}

	.post-row {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		padding: 1.2rem;
		text-decoration: none;
		color: inherit;
		border-radius: 12px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.post-row:hover {
		border-color: var(--accent-border);
		transform: translateY(-1px);
		box-shadow: var(--shadow-sm);
	}

	.post-row-image {
		flex-shrink: 0;
		width: 140px;
		height: 90px;
		border-radius: 8px;
		overflow: hidden;
	}

	.post-row-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 8px;
		display: block;
	}

	.post-row-body { flex: 1; min-width: 0; }

	.post-row-meta {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 0.4rem;
	}

	.tag-pill {
		font-size: 0.7em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent);
		background: var(--accent-dim);
		border: 1px solid var(--accent-border);
		padding: 0.15em 0.6em;
		border-radius: 999px;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.post-row-title {
		font-size: 1.05em;
		color: var(--text);
		margin: 0 0 0.3em;
		line-height: 1.3;
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
	}

	.post-row-desc {
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0 0 0.5em;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-row-footer { display: flex; gap: 1rem; align-items: center; }

	.post-row-date, .post-row-read {
		font-size: 0.78em;
		color: var(--text-dim);
	}

	.post-row-arrow {
		color: var(--text-dim);
		font-size: 1.1em;
		flex-shrink: 0;
		transition: transform 0.2s, color 0.2s;
	}

	.post-row:hover .post-row-arrow {
		transform: translateX(4px);
		color: var(--accent);
	}

	@media (max-width: 600px) {
		.post-row-image { display: none; }
		.post-row-arrow { display: none; }
	}
</style>
