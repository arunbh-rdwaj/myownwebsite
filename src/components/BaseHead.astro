---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	/** Processed image object from Astro's image pipeline */
	image?: ImageMetadata;
	/** Alt text for the OG image */
	imageAlt?: string;
	/** "website" for regular pages, "article" for blog posts */
	type?: 'website' | 'article';
	/** Post slug — used to build the /og/[slug].png URL for articles */
	ogSlug?: string;
	/** Article publish date (ISO string) — used when type="article" */
	pubDate?: Date;
	/** Article author name */
	author?: string;
	/** Article tags */
	tags?: string[];
}

const {
	title,
	description,
	image    = FallbackImage,
	imageAlt = title,
	type     = 'website',
	ogSlug,
	pubDate,
	author   = 'Arun Bhardwaj',
	tags     = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? '';

// For blog articles use the generated OG image at /og/[slug].png
// For other pages use the hero image (or fallback) directly
let ogImageURL: string;
let ogImageWidth: number;
let ogImageHeight: number;
let ogImageMime: string;

if (type === 'article' && ogSlug) {
	ogImageURL    = `${siteBase}/og/${ogSlug}.png`;
	ogImageWidth  = 1200;
	ogImageHeight = 630;
	ogImageMime   = 'image/png';
} else {
	ogImageURL = image.src.startsWith('http')
		? image.src
		: `${siteBase}${image.src}`;
	const ext = image.src.split('.').pop()?.toLowerCase() ?? 'jpg';
	const mimeMap: Record<string, string> = {
		jpg: 'image/jpeg', jpeg: 'image/jpeg',
		png: 'image/png',  webp: 'image/webp',
		gif: 'image/gif',  avif: 'image/avif',
	};
	ogImageMime   = mimeMap[ext] ?? 'image/jpeg';
	ogImageWidth  = image.width  ?? 1200;
	ogImageHeight = image.height ?? 630;
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Fonts -->
<Font cssVariable="--font-heading" preload />
<Font cssVariable="--font-body" preload />
<Font cssVariable="--font-mono" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{author && <meta name="author" content={author} />}

<!-- Open Graph -->
<meta property="og:type"        content={type} />
<meta property="og:site_name"   content={SITE_TITLE} />
<meta property="og:url"         content={canonicalURL} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={ogImageURL} />
<meta property="og:image:url"   content={ogImageURL} />
<meta property="og:image:secure_url" content={ogImageURL} />
<meta property="og:image:width"  content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:image:alt"    content={imageAlt} />
<meta property="og:image:type"   content={ogImageMime} />
<meta property="og:locale"       content="en_US" />

<!-- Article-specific Open Graph (only rendered for blog posts) -->
{type === 'article' && pubDate && (
	<meta property="article:published_time" content={pubDate.toISOString()} />
)}
{type === 'article' && author && (
	<meta property="article:author" content={author} />
)}
{type === 'article' && tags.map((tag) => (
	<meta property="article:tag" content={tag} />
))}

<!-- Twitter / X -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content="@arunbhardwaj" />
<meta name="twitter:creator"     content="@arunbhardwaj" />
<meta name="twitter:url"         content={canonicalURL} />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImageURL} />
<meta name="twitter:image:alt"   content={imageAlt} />
