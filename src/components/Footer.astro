---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-left">
			<a href="/" class="logo">Arun Bhardwaj</a>
			<p class="tagline">Exploring AI - Beyond the Hype.</p>
		</div>
		<div class="footer-links">
			<div class="link-group">
				<span class="group-label">Pages</span>
				<a href="/">Home</a>
				<a href="/blog">Blog</a>
				<a href="/portfolio">Portfolio</a>
				<a href="/about">About</a>
			</div>
			<div class="link-group">
				<span class="group-label">Connect</span>
				<a href="https://github.com/arunbh-rdwaj" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a href="https://www.linkedin.com/in/arun-bhardwaj-730b9920b/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				<a href="https://www.youtube.com/@CookWithArun1" target="_blank" rel="noopener noreferrer">YouTube</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Arun Bhardwaj. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: var(--bg-secondary);
		border-top: 1px solid var(--border);
		padding: 3em 2em 1.5em;
		transition: background 0.3s, border-color 0.3s;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
		padding-bottom: 2em;
		border-bottom: 1px solid var(--border);
	}

	.logo {
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		font-size: 1.05em;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text);
		text-decoration: none;
		display: block;
		margin-bottom: 0.5em;
		transition: color 0.15s;
	}

	.logo:hover { color: var(--accent); }

	.tagline {
		font-family: var(--font-body, 'Inter', system-ui, sans-serif);
		font-size: 0.85em;
		color: var(--text-dim);
		margin: 0;
	}

	.footer-links { display: flex; gap: 3rem; }

	.link-group { display: flex; flex-direction: column; gap: 0.5rem; }

	.group-label {
		font-family: var(--font-heading, 'Space Grotesk', system-ui, sans-serif);
		font-size: 0.72em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-dim);
		margin-bottom: 0.25rem;
	}

	.link-group a {
		font-family: var(--font-body, 'Inter', system-ui, sans-serif);
		font-size: 0.88em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}

	.link-group a:hover { color: var(--accent); }

	.footer-bottom {
		max-width: 1100px;
		margin: 1.5em auto 0;
		text-align: center;
	}

	.footer-bottom p {
		font-family: var(--font-body, 'Inter', system-ui, sans-serif);
		font-size: 0.8em;
		color: var(--text-dim);
		margin: 0;
	}

	@media (max-width: 600px) {
		.footer-inner { flex-direction: column; }
		.footer-links { gap: 2rem; }
	}
</style>
